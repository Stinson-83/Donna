# Claude / Donna runtime
ANTHROPIC_API_KEY=sk-ant-...
DONNA_MODEL=claude-sonnet-4-5
DONNA_REQUEST_TIMEOUT_S=45
DONNA_TRACE_FILE=donna_traces.jsonl
DONNA_SESSION_STORE=.donna_sessions.json
DONNA_USER_ID=local-dev
DONNA_GATE_LOG=donna_gate.jsonl

# LangSmith (optional)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=donna-dev

# Postgres (docker-compose default)
DATABASE_URL=postgresql+asyncpg://donna:donna@localhost:5432/donna

# Supermemory
SUPERMEMORY_API_KEY=sm_...

# FalkorDB (docker-compose default)
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_USERNAME=
FALKORDB_PASSWORD=

# OpenAI (Graphiti embedder)
OPENAI_API_KEY=sk-...

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=aura-verify-token

# Webhook routing
# RELAY_URL: when set, the entire webhook is forwarded to this URL and
#   nothing is processed locally. Use for full-mirroring.
# DEV_RELAY_URL + DEV_PHONE_NUMBERS: per-phone re-routing. Set both on the
#   instance that owns the public Meta webhook URL. Webhooks whose `from`
#   matches DEV_PHONE_NUMBERS (comma-separated, no `+`) are peeled off and
#   forwarded to DEV_RELAY_URL/webhook (e.g. ngrok tunnel to localhost),
#   the remainder still processes here. Lets you test locally without
#   touching the Meta dashboard each session.
RELAY_URL=
DEV_RELAY_URL=
DEV_PHONE_NUMBERS=

# Audio
# ElevenLabs (TTS — outbound voice notes). Flash v2.5 ≈ 200ms latency.
# Override ELEVENLABS_VOICE_ID for a different persona.
# ELEVENLABS_MODEL_ID is the TTS model.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=WAhoMTNdLdMoq1j3wf3I
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# ELEVENLABS_VOICE_SPEED: 0.7 (slow) – 1.2 (fast). Default 1.2 = max snappiness.
ELEVENLABS_VOICE_SPEED=1.2
# Deepgram (STT — inbound voice notes). Nova-3 multilingual.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
# Voice feature flag. When false: the voice_response marker in send_burst is
# stripped (Donna falls back to text); inbound transcription still runs.
DONNA_VOICE_ENABLED=true
# Hard cap on character count synthesized per turn. Past this we fall back to
# text. WA voice notes feel wrong past ~600 chars (≈45s) anyway.
DONNA_VOICE_MAX_CHARS=600
