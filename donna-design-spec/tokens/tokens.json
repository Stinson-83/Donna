{
  "$comment": "Donna design tokens v1.0 — extracted from approved mocks (live v6, history v3, dashboard v3, island/lockscreen). Single source of truth. Compile to CSS vars + tailwind theme. Never hardcode hex in components.",
  "color": {
    "bg":        { "base": "#F6F1EA", "deep": "#EFE8DF", "light": "#FCF8F2" },
    "surface":   { "card": "#FFFFFF", "cardWarm": "#FDF9F5", "settled": "rgba(255,255,255,0.5)" },
    "ink":       { "base": "#201A14", "60": "#6F665C", "40": "#A59B8F" },
    "border":    { "hairline": "rgba(63,46,35,0.08)", "soft": "rgba(63,46,35,0.05)" },
    "accent":    { "base": "#7B5544", "light": "#8A604E", "deep": "#6C4A3A", "press": "#654435" },
    "espresso":  { "base": "#251D16", "light": "#3A2C20", "deep": "#1B140E" },
    "cream":     { "base": "#F3EBE1", "60": "rgba(243,235,225,0.62)", "40": "rgba(243,235,225,0.4)", "line": "rgba(243,235,225,0.14)" },
    "copper":    { "base": "#C99A7E", "glow": "rgba(201,154,126,0.8)" },
    "green":     { "base": "#3D7A4E", "light": "#4C9160", "onDark": "#5E9C72" },
    "wa":        { "base": "#2F6B45", "light": "#3E7E53", "deep": "#27573A", "tint": "#EFF4ED", "line": "rgba(47,107,69,0.16)" },
    "amber":     { "base": "#B07A3E", "tint": "rgba(176,122,62,0.13)" },
    "danger":    { "base": "#C05A45", "deep": "#A8462F" }
  },
  "typography": {
    "family": {
      "display": "'EB Garamond', Georgia, serif",
      "body": "'Red Hat Text', -apple-system, sans-serif"
    },
    "law": "Garamond appears ONLY as: nav titles, large numerals (times, prices), the d-mark. Always upright, weight 500-600. Never italic except the wordmark. Red Hat carries everything else.",
    "scale": {
      "navTitle":    { "family": "display", "size": 28, "weight": 600, "tracking": "-0.01em" },
      "numeralHero": { "family": "display", "size": 38, "weight": 600, "tracking": "-0.015em" },
      "numeralLg":   { "family": "display", "size": 32, "weight": 600 },
      "numeralMd":   { "family": "display", "size": 26, "weight": 600 },
      "bodyLive":    { "family": "body", "size": 16.5, "weight": 400, "lineHeight": 1.62 },
      "bodyCard":    { "family": "body", "size": 14.5, "weight": 400, "lineHeight": 1.5 },
      "bodyHistory": { "family": "body", "size": 14.5, "weight": 400, "lineHeight": 1.52 },
      "titleCard":   { "family": "body", "size": 14, "weight": 700 },
      "button":      { "family": "body", "size": 14.5, "weight": 700 },
      "label":       { "family": "body", "size": 10.5, "weight": 700, "tracking": "0.08em", "transform": "uppercase" },
      "sub":         { "family": "body", "size": 12.5, "weight": 500 },
      "micro":       { "family": "body", "size": 11, "weight": 600 }
    }
  },
  "radius": {
    "card": 20, "cardLight": 18, "row": 15, "bubble": 18, "bubbleTail": 6,
    "button": 13, "buttonSm": 11, "pill": 24, "tile": 14, "island": 100
  },
  "elevation": {
    "law": "Depth is semantic, never decorative. needsYou floats highest; informational sits mid; settled is sunk flush.",
    "needsYou": "0 2px 4px rgba(32,22,14,0.18), 0 10px 24px rgba(32,22,14,0.22), 0 30px 60px rgba(32,22,14,0.25), inset 0 1px 0 rgba(255,255,255,0.09)",
    "raised":   "0 1px 1px rgba(63,42,30,0.05), 0 3px 6px rgba(63,42,30,0.05), 0 10px 20px rgba(63,42,30,0.06), inset 0 1.5px 0 #FFF",
    "low":      "0 1px 2px rgba(63,42,30,0.05), 0 4px 10px rgba(63,42,30,0.04), inset 0 1px 0 #FFF",
    "settled":  "inset 0 1.5px 3px rgba(63,42,30,0.05)",
    "accentBtn":"0 2px 5px rgba(101,68,53,0.35), 0 8px 18px rgba(101,68,53,0.22), inset 0 1px 0 rgba(255,255,255,0.25)",
    "espressoBtn":"0 2px 6px rgba(32,22,14,0.3), 0 9px 20px rgba(32,22,14,0.25), inset 0 1px 0 rgba(255,255,255,0.12)"
  },
  "gradient": {
    "appBg":      "radial-gradient(130% 55% at 50% -12%, {color.bg.light} 0%, {color.bg.base} 55%, {color.bg.deep} 100%)",
    "darkCard":   "radial-gradient(140% 90% at 20% 0%, {color.espresso.light} 0%, {color.espresso.base} 52%, {color.espresso.deep} 100%)",
    "userBubble": "linear-gradient(180deg, #88604E 0%, {color.accent.base} 65%, {color.accent.deep} 100%)",
    "waBubble":   "linear-gradient(180deg, {color.wa.light} 0%, {color.wa.base} 65%, {color.wa.deep} 100%)",
    "creamBtn":   "linear-gradient(180deg, #FBF6EE 0%, {color.cream.base} 100%)",
    "lightCard":  "linear-gradient(180deg, #FFFFFF 0%, {color.surface.cardWarm} 100%)",
    "talkBtn":    "radial-gradient(120% 150% at 25% 0%, #3C2D20 0%, {color.espresso.base} 60%, #19120C 100%)"
  },
  "texture": {
    "grain": "SVG fractalNoise baseFrequency 0.9, 2 octaves, white at alpha 0.05, opacity 0.5 — dark surfaces only"
  },
  "motion": {
    "spring": "cubic-bezier(0.22, 1, 0.36, 1)",
    "press": "translateY(1.5px), 80ms ease",
    "drawer": "380ms spring",
    "law": "No entrance animation theater. Allowed motion: press travel, drawer slide, working dots, shimmer on working text, voice waveform, breathing live dot, the morphing call form. Always honor prefers-reduced-motion."
  },
  "placement": {
    "cardTilt": "-0.4deg dark cards, +0.3deg settled receipts. Nothing else rotates.",
    "screenPadding": 18,
    "cardPaddingX": 18,
    "touchTargetMin": 44
  },
  "spacing": {
    "$comment": "4px base grid. Use these steps only.",
    "scale": [4, 8, 12, 16, 20, 24, 32, 44],
    "blockGap": 22, "turnGap": 16, "msgGap": 5, "sectionLabelGap": 9
  },
  "fonts": {
    "load": {
      "EB Garamond": [500, 600],
      "Red Hat Text": [400, 500, 600, 700]
    },
    "source": "Google Fonts now; self-host woff2 in the bundle before ship (WebView offline).",
    "fallbacks": { "display": "Georgia, serif", "body": "-apple-system, BlinkMacSystemFont, sans-serif" }
  },
  "input": {
    "composer": {
      "height": 47, "radius": 24, "paddingX": 17, "fontSize": 15,
      "bg": "{color.surface.card}", "border": "{color.border.hairline}",
      "placeholderColor": "{color.ink.40}", "placeholderText": "Message",
      "textColor": "{color.ink.base}", "caretColor": "{color.accent.base}",
      "focus": "border-color {color.accent.base} at 40% opacity; no glow, no ring on touch",
      "elevation": "{elevation.low}"
    },
    "searchField": { "height": 34, "radius": 17, "fontSize": 13 }
  },
  "states": {
    "pressed": "transform translateY(1.5px); darken gradient to *.press/.deep variant; 80ms",
    "disabled": "opacity 0.4; pointer-events none; never change color tokens",
    "focusVisible": "2px outline {color.accent.base} at 50%, offset 2px — keyboard/switch access only, suppressed for touch",
    "selectedRow": "background rgba(123,85,68,0.08); label color {color.accent.base}",
    "destructiveConfirm": "danger tokens appear only after an explicit confirm step"
  },
  "icons": {
    "set": "custom inline SVG (or Lucide configured to match)",
    "grid": 24, "strokeWidth": 1.7, "strokeButtons": 1.8,
    "caps": "round", "joins": "round", "fill": "none",
    "sizes": { "tab": 22, "control": 17, "inline": 14, "micro": 12 },
    "law": "Single-weight stroke icons only. No filled icons except brand glyphs (WA, service logos) and the d-mark."
  },
  "zIndex": { "nav": 10, "scrim": 40, "drawer": 50, "callOverlay": 60, "toast": 70 },
  "skeleton": {
    "bg": "rgba(63,46,35,0.06)", "highlight": "rgba(255,255,255,0.5)",
    "radius": "match the component it replaces", "shimmer": "1.8s linear, honors prefers-reduced-motion",
    "law": "Skeletons only for cards and rows. Text content never skeletons — show nothing, then the message."
  },
  "formats": {
    "time": "8:45 PM (space before meridiem, no leading zero)",
    "money": "S$818 (currency prefix, no space, no decimals unless < S$10)",
    "date": "Thu 11 Jun (nav) · Jun 16 (inline)",
    "duration": "4:12 (m:ss) · 43m (compact countdown)",
    "richText": "body supports **bold** only. No links, no italics, no lists inside cards."
  }
}
