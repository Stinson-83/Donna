# Mock mode: run the UI with NO backend, NO API key, NO database.
# ON by default (so `npm run dev` works on a fresh clone). Set to 0 once the
# backend is running to talk to the real Donna brain.
VITE_MOCK=1

# Backend base URL (only used when VITE_MOCK=0). Local default below; for the
# deployed demo set this to your Railway URL.
VITE_API_BASE=http://localhost:8000
